<?xml version="1.0"?>
<robot name="robot_arm">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.050" radius="0.1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.050" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>
    
  <joint name="base_joint" type="revolute">
    <parent link="base_link"/>
    <child link="base_rot"/>
    <origin xyz="0 0 0.05" rpy="0 0 0" />
    <axis xyz="0 0 -1"/>
    <limit lower="-6.28" upper="6.28" effort="150" velocity="3.0"/>
  </joint>

  <link name="base_rot">
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.1 0.07" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.07" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0004" ixy="0.0" ixz="0.0" iyy="0.0004" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="base_rot"/>
    <child link="arm1"/>
    <origin xyz="0 0 0.07" rpy="0 0 0" />
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="2.0"/>
  </joint>

  <link name="arm1">
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.5" radius="0.02"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.5" radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0008" ixy="0.0" ixz="0.0" iyy="0.00015" iyz="0.0" izz="0.00015"/>
    </inertial>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="arm1"/>
    <child link="arm2"/>
    <origin xyz="0.08 0 0.5" rpy="0 0 0" />
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="2.5"/>
  </joint>
    
  <link name="arm2">
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.5" radius="0.02"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.5" radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0008" ixy="0.0" ixz="0.0" iyy="0.00015" iyz="0.0" izz="0.00015"/>
    </inertial>
  </link>

  <joint name="ee_joint" type="fixed">
    <parent link="arm2"/>
    <child link="ee_link"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
  </joint>

  <link name="ee_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.1 0.05" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.05" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.00017" ixy="0.0" ixz="0.0" iyy="0.00017" iyz="0.0" izz="0.00008"/>
    </inertial>
  </link>
</robot>
